# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/shoestore"

# JWT — ҲАТМАН ду калиди ГУНОГУН!
JWT_ACCESS_SECRET="access_super_secret_key_minimum_32_characters_long"
JWT_REFRESH_SECRET="refresh_super_secret_key_minimum_32_characters_long"

# App
PORT=3000
NODE_ENV=development

# Frontend URLs
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# WhatsApp
WHATSAPP_NUMBER=+992XXXXXXXXX

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
